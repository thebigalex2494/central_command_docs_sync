@startuml MaestroPlanner
start
:Inicio: Generar Plan Maestro;
if (¿Existe Plan Actual?) then (Sí)
  :Leer Asignaciones Existentes (Snapshot);
else (No)
  :Iniciar Mapa Vacío;
endif
:Ejecutar Engine.scanData() en Hojas Origen;
:Iterar Facturas Frescas;
if (¿Factura existe en Snapshot?) then (Sí)
  :Aplicar Semana Guardada a Factura Fresca;
else (No)
  :Marcar como Pendiente / Nueva;
endif
:Generar Matriz de Presupuesto Semanal (Header);
:Escribir Tabla Consolidada (Rehidratada);
stop
@enduml